# Reverse-proxy block for cipher-agent.syamxm.com.
# Copy into your nginx conf.d (e.g. ~/nginx/conf.d/default.conf) and reload nginx.
# The /ws block carries the WebSocket upgrade headers needed by the field channel.

server {
    listen 80;
    server_name cipher-agent.syamxm.com;

    location /ws {
        proxy_pass http://cipher_agent:8067;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://cipher_agent:8067;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
